# Copy to `.env` and fill in locally. Never commit `.env` or real secrets.
# See `app/config.py` for all settings and env name aliases.

# Database
DATABASE_URL=
# or DB_CONNECTION_STRING=

# JWT
SECRET_KEY=

# Divine API (panchang fallback when not using Swiss / panchang_source=divine)
DIVINE_API_KEY=
DIVINE_ACCESS_TOKEN=

# Panchang: auto | swiss | divine
PANCHANG_SOURCE=auto

# Google Maps (optional)
GOOGLE_MAPS_API_KEY=

# GeoNames (optional — nearby place / ocean / natural features)
GEONAMES_USERNAME=

# TTS / voice (optional)
GOOGLE_CLOUD_TTS_CREDENTIALS_PATH=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Email / SMS (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
BREVO_API_KEY=
